rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Публичные ассеты темплейтов
    match /template/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Фото юзера: только владелец, только image/*, лимит размера.
    match /user_uploads/{uid}/{allPaths=**} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && (
        request.resource == null || (
          request.resource.contentType.matches('image/.*') &&
          request.resource.size < 40 * 1024 * 1024
        )
      );
    }

    // (на будущее) результаты
    match /outputs/{uid}/{allPaths=**} {
      allow read: if isOwner(uid);
      allow write: if false;
    }
  }
}
