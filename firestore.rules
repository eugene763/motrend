rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Шаблоны: только чтение (список активных грузит приложение)
    match /templates/{templateId} {
      allow read: if true;
      allow write: if false;
    }

    // Профиль пользователя: только свой документ; кредиты менять нельзя
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null && request.auth.uid == userId
        && (!('creditsBalance' in request.resource.data) || request.resource.data.creditsBalance == 0);
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.creditsBalance == resource.data.creditsBalance;
      allow delete: if false;
    }

    // Задачи: создаёт только Cloud Function (createJob); клиент может писать только URL/пути загрузок и updatedAt
    match /jobs/{jobId} {
      allow read: if request.auth != null && resource.data.uid == request.auth.uid;
      allow create: if false;
      allow update: if request.auth != null && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['inputImageUrl', 'inputImagePath', 'referenceVideoUrl', 'referenceVideoPath', 'updatedAt']);
      allow delete: if false;
    }

    // Билеты скачивания: только Cloud Functions (getDownloadTicket / downloadResult)
    match /downloadTickets/{ticketId} {
      allow read, write: if false;
    }

  }
}
