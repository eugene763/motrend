rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAllowedUserUpload() {
      return request.resource == null || (
        (
          request.resource.contentType == 'image/jpeg' &&
          request.resource.size < 40 * 1024 * 1024
        ) || (
          (
            request.resource.contentType == 'video/mp4' ||
            request.resource.contentType == 'video/quicktime'
          ) &&
          request.resource.size < 200 * 1024 * 1024
        )
      );
    }

    // Публичные ассеты темплейтов
    match /template/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Пользовательские загрузки (фото/видео): только владелец, с лимитом.
    match /user_uploads/{uid}/{allPaths=**} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid) && isAllowedUserUpload();
    }

    // (на будущее) результаты
    match /outputs/{uid}/{allPaths=**} {
      allow read: if isOwner(uid);
      allow write: if false;
    }
  }
}
