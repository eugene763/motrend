rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function userCreateValid() {
      return request.resource.data.keys().hasOnly([
          'email',
          'country',
          'language',
          'updatedAt',
        ]);
    }

    function userUpdateValid() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        'email',
        'country',
        'language',
        'updatedAt',
      ]);
    }

    // Public catalog: client can only read templates.
    match /templates/{templateId} {
      allow read: if true;
      allow write: if false;
    }

    // User profile: only owner can read/update. Credits are server-managed.
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && userCreateValid();
      allow update: if isOwner(uid) && userUpdateValid();
      allow delete: if false;
    }

    // Jobs: owner can read and only provide upload input fields.
    match /jobs/{jobId} {
      allow read: if isSignedIn() && resource.data.uid == request.auth.uid;
      allow create: if false;
      allow update: if isSignedIn()
        && resource.data.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'inputImageUrl',
          'inputImagePath',
          'referenceVideoUrl',
          'referenceVideoPath',
          'updatedAt',
        ]);
      allow delete: if false;
    }
  }
}
